# ─────────────────────────────────────────────
#  DevOps LMS — Environment Variables
#  Copy this file to .env and fill in your values
#  NEVER commit .env to GitHub
# ─────────────────────────────────────────────

# MongoDB Atlas connection string
# Get this from: MongoDB Atlas > Clusters > Connect > Drivers
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/devops-lms?retryWrites=true&w=majority

# JWT secret key — use any long random string
# You can generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_key_change_this_in_production

# Port the backend server will run on
PORT=5000

# Environment (development | production)
NODE_ENV=development
